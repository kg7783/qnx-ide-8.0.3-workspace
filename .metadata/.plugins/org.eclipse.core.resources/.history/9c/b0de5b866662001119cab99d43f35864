#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <unistd.h>
#include <EGL/egl.h>
#include <GLES2/gl2.h>
#include <screen/screen.h>

static const char *vshader =
    "attribute vec4 pos;\n"
    "varying vec2 uv;\n"
    "void main() {\n"
    "  gl_Position = pos;\n"
    "  uv = pos.xy * 0.5 + 0.5;\n"
    "}\n";

static const char *fshader =
    "precision highp float;\n"
    "uniform float t;\n"
    "varying vec2 uv;\n"
    "void main() {\n"
    "  vec2 p = uv * 4.0 - 2.0;\n"
    "  float v = sin(p.x + t) * cos(p.y + t * 0.7) + sin((p.x * 1.5 + p.y * 1.2) * 3.0 + t * 1.3) * 0.5;\n"
    "  v = v * 0.5 + 0.5;\n"
    "  gl_FragColor = vec4(cos(v * 6.28 + t * 0.3) * 0.5 + 0.5, sin(v * 6.28 - t * 0.2) * 0.5 + 0.5, cos(v * 6.28 + t * 0.5 + 1.0) * 0.5 + 0.5, 1.0);\n"
    "}\n";

static GLuint compile(GLenum type, const char *src) {
    GLuint s = glCreateShader(type);
    glShaderSource(s, 1, &src, NULL);
    glCompileShader(s);
    return s;
}

int main(int argc, char *argv[]) {
    screen_context_t ctx;
    screen_window_t win;
//    int size[2] = {1280, 768};
    int size[2] = {1920, 1200};
    int pos[2] = {0, 0};
    int format = SCREEN_FORMAT_RGBA8888;
    int usage = SCREEN_USAGE_OPENGL_ES2;
    int bufcount = 2;

    screen_create_context(&ctx, 0);
    screen_create_window(&win, ctx);

    screen_set_window_property_iv(win, SCREEN_PROPERTY_USAGE, &usage);
    screen_set_window_property_iv(win, SCREEN_PROPERTY_FORMAT, &format);
    screen_set_window_property_iv(win, SCREEN_PROPERTY_SIZE, size);
    screen_set_window_property_iv(win, SCREEN_PROPERTY_POSITION, pos);

    screen_create_window_buffers(win, bufcount);

    EGLDisplay dpy = eglGetDisplay(EGL_DEFAULT_DISPLAY);
    if (dpy == EGL_NO_DISPLAY) return 1;
    eglInitialize(dpy, NULL, NULL);

    EGLint attribs[] = { EGL_SURFACE_TYPE, EGL_WINDOW_BIT, EGL_RED_SIZE, 8, EGL_GREEN_SIZE, 8, EGL_BLUE_SIZE, 8, EGL_ALPHA_SIZE, 8, EGL_RENDERABLE_TYPE, EGL_OPENGL_ES2_BIT, EGL_NONE };
    EGLConfig config;
    EGLint nconfig;
    eglChooseConfig(dpy, attribs, &config, 1, &nconfig);
    if (nconfig == 0) return 1;

    static const EGLint ctx_attribs[] = { EGL_CONTEXT_CLIENT_VERSION, 2, EGL_NONE };
    EGLContext egl_ctx = eglCreateContext(dpy, config, EGL_NO_CONTEXT, ctx_attribs);
    if (egl_ctx == EGL_NO_CONTEXT) return 1;

    EGLSurface egl_surf = eglCreateWindowSurface(dpy, config, win, NULL);
    if (egl_surf == EGL_NO_SURFACE) return 1;

    eglMakeCurrent(dpy, egl_surf, egl_surf, egl_ctx);
    eglSwapInterval(dpy, 1);

    GLuint vs = compile(GL_VERTEX_SHADER, vshader);
    GLuint fs = compile(GL_FRAGMENT_SHADER, fshader);
    GLuint prog = glCreateProgram();
    glAttachShader(prog, vs);
    glAttachShader(prog, fs);
    glBindAttribLocation(prog, 0, "pos");
    glLinkProgram(prog);
    GLint tu = glGetUniformLocation(prog, "t");
    glUseProgram(prog);

    GLfloat verts[] = { -1,-1,  1,-1,  -1,1,  1,1 };
    GLuint vbo;
    glGenBuffers(1, &vbo);
    glBindBuffer(GL_ARRAY_BUFFER, vbo);
    glBufferData(GL_ARRAY_BUFFER, sizeof(verts), verts, GL_STATIC_DRAW);
    glEnableVertexAttribArray(0);
    glVertexAttribPointer(0, 2, GL_FLOAT, GL_FALSE, 0, 0);

    screen_event_t ev;
    screen_create_event(&ev);
    int running = 1;
    float t = 0;

    while (running) {
        int limit = 10;
        while (limit--) {
            if (screen_get_event(ctx, ev, 0) != 0) break;
            int type;
            screen_get_event_property_iv(ev, SCREEN_PROPERTY_TYPE, &type);
            if (type == SCREEN_EVENT_KEYBOARD) {
                int sym;
                screen_get_event_property_iv(ev, SCREEN_PROPERTY_SYM, &sym);
                if (sym == 27 || sym == 'q' || sym == 'Q')
                    running = 0;
            }
        }

        t += 0.02;
        glUniform1f(tu, t);
        glDrawArrays(GL_TRIANGLE_STRIP, 0, 4);
        eglSwapBuffers(dpy, egl_surf);
    }

    screen_destroy_event(ev);
    eglDestroySurface(dpy, egl_surf);
    eglDestroyContext(dpy, egl_ctx);
    eglTerminate(dpy);
    screen_destroy_window(win);
    screen_destroy_context(ctx);
    return 0;
}
